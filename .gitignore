# =========================
# Python
# =========================
__pycache__/
*.py[codz]
*$py.class

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checking / linting
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/
.cache

# uv state — requirements.txt is the lockfile of record
uv.lock

# =========================
# Virtual envs + secrets
# =========================
.venv/
venv/
env/
ENV/
.env
.env.production
.envrc
# Timestamped backups (e.g. scripts/mint_mcp_jwt.py --write makes one before
# editing) — same secrets as the file they back up, so never commit them.
.env*.bak-*

# Self-issued JWT signing key (minted by scripts/mint_mcp_jwt.py — never commit)
secrets/
*.pem

# =========================
# Jupyter / notebooks
# =========================
.ipynb_checkpoints/

# =========================
# IDEs / editors
# =========================
.idea/
.vscode/

# =========================
# OS cruft
# =========================
.DS_Store
Thumbs.db

# =========================
# Project-specific
# =========================
tmp

# Live over-the-wire e2e checks — kept local (run against a live stack).
e2e/

# The owner's knowledge base — personal context data, never committed.
# (The filesystem-backed `knowledge` provider writes here; see example.env.)
knowledge/

# Google credentials — OAuth token caches + the service account key
# (see docs/GOOGLE.md). Personal credentials, never committed.
gmail_token.json
calendar_token.json
google-service-account.json

# Claude Code: ignore local/personal state. The shared dev-time skills live in
# .agents/skills/ (committed); .claude/skills is a committed symlink into it —
# no trailing slash on the re-include, or it would only match a real directory.
# Add more re-include lines (e.g. !.claude/commands/) to ship other shared
# Claude config too.
.claude/*
!.claude/skills
!.claude/settings.json

# Optional: local PyPI creds (uncomment if you ever create it)
# .pypirc
