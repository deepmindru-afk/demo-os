# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Owner identity — who Context treats as its owner. SET THIS FIRST.
# Use the email you sign in to os.agno.com with: the AgentOS UI sends it as
# your verified identity on every request, so once it matches OWNER_ID you get
# the full surface automatically. The owner gets the full toolset (filing,
# retrieval, the inbound queue); everyone else can only leave updates
# (capture-only). Identity is matched against the verified user_id on each run
# (JWT `sub` in prod, Slack email when resolve_user_identity is on).
#   - Comma-separated so one person's ids across spaces all resolve to the owner
#     (e.g. "a@agno.com,U12345,auth0|abc"). The FIRST entry is canonical —
#     the user_id the inbound queue rows are written under.
# ---------------------------------------------------------------------------
# OWNER_ID=my@email.com

# ---------------------------------------------------------------------------
# Owner display name — rendered into the agent's prompt ("Bob's context").
# Cosmetic only: never matched as an identity (that's OWNER_ID).
# ---------------------------------------------------------------------------
# OWNER_NAME=

# ---------------------------------------------------------------------------
# Production — JWT verification for AgentOS.
# AgentOS enables RBAC whenever RUNTIME_ENV=prd.
# Without this key, prod refuses to serve traffic. Generate the keypair at
# os.agno.com (your OS → Settings → Token Based Authorization) — the Railway
# up.sh script prints your domain and pauses so you can mint it mid-deploy.
# Paste the full PEM block, no surrounding quotes.
# Set `authorization=False` in app/main.py to opt out (not recommended).
# ---------------------------------------------------------------------------
# JWT_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkq...
# -----END PUBLIC KEY-----

# ---------------------------------------------------------------------------
# AgentOS scheduler base URL. Defaults to http://127.0.0.1:8000 for local development.
# When AgentOS is deployed to a different domain, set this to the public URL.
# ---------------------------------------------------------------------------
# AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Web — the `web` context provider uses Parallel's MCP server.
#   PARALLEL_API_KEY set  →  authenticated SDK / endpoint (higher rate limits)
#   unset                 →  keyless /mcp endpoint (good for dev)
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Slack — set both to enable the Slack interface (see docs/SLACK.md).
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***) — also activates the
#                         `slack` context provider (query_slack) on its own
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Gmail + Google Calendar — the `gmail` and `calendar` context providers
# (see docs/GOOGLE.md). Configure ONE of the two auth paths:
#
# 1) Service account (headless — recommended for deploys; Gmail requires
#    domain-wide delegation, so this path needs Google Workspace):
#   GOOGLE_SERVICE_ACCOUNT_FILE  path to the JSON key
#   GOOGLE_DELEGATED_USER        the mailbox/calendar to act as (your email)
#   GOOGLE_SERVICE_ACCOUNT_JSON_B64  alternative to the file path for
#                                platforms without secret-file mounts: the
#                                JSON key, base64-encoded (entrypoint
#                                materializes it at startup)
#
# 2) OAuth (personal accounts): set these, then mint the consent tokens
#    locally once — docs/GOOGLE.md walks through it.
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
#   GOOGLE_PROJECT_ID=
# ---------------------------------------------------------------------------
# GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_DELEGATED_USER=
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Knowledge base — the `knowledge` source. Filesystem-backed by default
# (wiki/knowledge/, gitignored). We recommend pointing it at a Git-backed
# specs repo instead — durable storage with an audit trail.
#   WIKI_REPO_URL     git remote, e.g. https://github.com/you/your-specs.git
#   WIKI_GITHUB_TOKEN GitHub token with push access to that repo
#   WIKI_BRANCH       branch to commit to (default: main)
#   WIKI_LOCAL_PATH   local checkout path (default: managed temp dir)
# ---------------------------------------------------------------------------
# WIKI_REPO_URL=
# WIKI_GITHUB_TOKEN=
# WIKI_BRANCH=main
# WIKI_LOCAL_PATH=

# ---------------------------------------------------------------------------
# Scheduler-to-OS auth token. Auto-generated per process when unset — fine
# for one replica. Running multiple replicas behind one URL (railway.json
# ships two)? Set it so every replica accepts every replica's scheduler
# calls, e.g.: openssl rand -base64 32
# ---------------------------------------------------------------------------
# INTERNAL_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=context
# DB_PASS=context
# DB_DATABASE=context
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Dev ergonomics — compose sets all three for local development.
#   RUNTIME_ENV   "dev" enables hot-reload and disables JWT (default: prd)
#   AGNO_DEBUG    verbose Agno debug logs (default: False)
#   WAIT_FOR_DB   entrypoint blocks until Postgres is reachable (default: False)
# ---------------------------------------------------------------------------
# RUNTIME_ENV=prd
# AGNO_DEBUG=False
# WAIT_FOR_DB=False
