# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Owner identity
# Comma-separated list of identities that should be considered as the owner.
# ---------------------------------------------------------------------------
# OWNER_ID=owner@example.com

# ---------------------------------------------------------------------------
# Owner display name
# The display name of the owner, used in the agent's prompt.
# ---------------------------------------------------------------------------
# OWNER_NAME=

# ---------------------------------------------------------------------------
# JWT verification for AgentOS.
# AgentOS enables RBAC whenever RUNTIME_ENV=prd.
# Without this key, AgentOS refuses to serve traffic.
# Generate the keypair at os.agno.com (your OS → Settings → Token Based Authorization)
# and paste the full PEM block, no surrounding quotes.
# ---------------------------------------------------------------------------
# JWT_VERIFICATION_KEY=

# ---------------------------------------------------------------------------
# AgentOS scheduler URL. Set this to the public URL of your AgentOS instance.
# ---------------------------------------------------------------------------
# AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Web context provider
# The `web` context provider uses Parallel's MCP server.
# Set PARALLEL_API_KEY to use the authenticated SDK / endpoint (higher rate limits)
# or leave it unset to use the keyless /mcp endpoint (ok for dev).
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Slack context provider
# Set both SLACK_BOT_TOKEN and SLACK_SIGNING_SECRET to enable the Slack interface.
# SLACK_BOT_TOKEN is the Bot User OAuth Token (xoxb-***) and also activates the
# `slack` context provider (query_slack) on its own.
# SLACK_SIGNING_SECRET is the Signing Secret (Basic Information → App Credentials).
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Gmail + Google Calendar context providers
# Configure ONE of the two auth paths:
#
# 1) Service account (headless — recommended for deploys; Gmail requires
#    domain-wide delegation, so this path needs Google Workspace).
#   GOOGLE_SERVICE_ACCOUNT_FILE  path to the JSON key
#   GOOGLE_DELEGATED_USER        the mailbox/calendar to act as (your email)
#   GOOGLE_SERVICE_ACCOUNT_JSON_B64  alternative to the file path for
#                                platforms without secret-file mounts.
#                                The JSON key, base64-encoded (entrypoint
#                                materializes it at startup).
#
# 2) OAuth (personal accounts): set these, then mint the consent tokens
#    locally once.
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
#   GOOGLE_PROJECT_ID=
# ---------------------------------------------------------------------------
# GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_DELEGATED_USER=
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Knowledge base
# The `knowledge` source. Filesystem-backed by default (knowledge/, gitignored).
# We recommend pointing it at a Git-backed specs repo instead — durable storage with an audit trail.
#   KNOWLEDGE_REPO_URL     git remote, e.g. https://github.com/you/your-specs.git
#   KNOWLEDGE_GITHUB_TOKEN GitHub token with push access to that repo
#   KNOWLEDGE_BRANCH       branch to commit to (default: main)
#   KNOWLEDGE_LOCAL_PATH   local checkout path (default: managed temp dir)
# ---------------------------------------------------------------------------
# KNOWLEDGE_REPO_URL=
# KNOWLEDGE_GITHUB_TOKEN=
# KNOWLEDGE_BRANCH=main
# KNOWLEDGE_LOCAL_PATH=

# ---------------------------------------------------------------------------
# Scheduler-to-OS auth token. Auto-generated per process when unset — fine
# for one replica. Running multiple replicas behind one URL (railway.json
# ships two)? Set it so every replica accepts every replica's scheduler
# calls, e.g.: openssl rand -base64 32
# ---------------------------------------------------------------------------
# INTERNAL_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=context
# DB_PASS=context
# DB_DATABASE=context
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Dev ergonomics — compose sets all three for local development.
#   RUNTIME_ENV   "dev" enables hot-reload and disables JWT (default: prd)
#   AGNO_DEBUG    verbose Agno debug logs (default: False)
#   WAIT_FOR_DB   entrypoint blocks until Postgres is reachable (default: False)
# ---------------------------------------------------------------------------
# RUNTIME_ENV=prd
# AGNO_DEBUG=False
# WAIT_FOR_DB=False
